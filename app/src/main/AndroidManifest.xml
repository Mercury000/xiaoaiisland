<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 获取节假日数据 -->
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:label="@string/app_name"
        android:description="@string/app_description"
        android:icon="@mipmap/ic_launcher"
        android:allowBackup="false"
        android:theme="@style/Theme.XiaoaiIsland">

        <!-- 声明这是一个 Xposed/LSPosed 模块 -->
        <meta-data
            android:name="xposedmodule"
            android:value="true" />

        <!-- 模块描述 -->
        <meta-data
            android:name="xposeddescription"
            android:value="将小爱同学课程表提醒通知转为小米超级岛通知" />

        <!-- 最低 Xposed API 版本 -->
        <meta-data
            android:name="xposedminversion"
            android:value="101" />

        <!--
            LSPosed 作用域声明（仅注入目标包名进程）
            也可在 LSPosed 管理器中手动勾选作用域
        -->
        <meta-data
            android:name="xposedscope"
            android:value="com.miui.voiceassist;com.android.deskclock" />

        <!-- 模块主界面（MODULE_SETTINGS 供 LSPosed 打开，与桌面图标无关） -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="io.github.libxposed.category.MODULE_SETTINGS" />
            </intent-filter>
        </activity>

        <!-- 桌面图标别名入口（禁用此项即可隐藏桌面图标） -->
        <activity-alias
            android:name=".MainActivityAlias"
            android:targetActivity=".MainActivity"
            android:exported="true"
            android:enabled="true"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <!-- 接收目标进程发来的总周数更新 -->
        <receiver android:name=".TotalWeekReceiver" android:exported="true">
            <intent-filter>
                <action android:name="com.xiaoai.islandnotify.ACTION_UPDATE_TOTAL_WEEK" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
